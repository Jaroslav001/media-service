# App
PORT=3003
NODE_ENV=development

# Database
DATABASE_URL="postgresql://sail:password@localhost:5432/media_service"

# Redis — DB index 2 (separate from chat)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=2

# JWT — shared secret with Laravel
JWT_SECRET=your-shared-jwt-secret

# S3 / DigitalOcean Spaces
S3_REGION=fra1
S3_ENDPOINT=https://fra1.digitaloceanspaces.com
S3_ACCESS_KEY_ID=your-access-key
S3_SECRET_ACCESS_KEY=your-secret-key
S3_BUCKET=your-bucket
S3_CDN_URL=https://your-bucket.fra1.cdn.digitaloceanspaces.com

# Webhook
WEBHOOK_DEFAULT_URL=http://localhost:8080/api/internal/media/webhook
WEBHOOK_SECRET=your-webhook-secret

# CORS
CORS_ORIGINS=http://localhost:3000
